# Local dev only. Copy to `.env` and paste a free key from
# https://www.football-data.org/client/register
# Without a key the app shows a setup screen.
FOOTBALL_DATA_API_KEY=

# Optional: pool extra free accounts to raise the rate limit (10 req/min each).
# Either comma-separate them in FOOTBALL_DATA_API_KEY above, or set these:
# FOOTBALL_DATA_API_KEY_2=
# FOOTBALL_DATA_API_KEY_3=
